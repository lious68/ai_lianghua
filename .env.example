# OpenClaw Environment Configuration Template
# Copy this file to .env and fill in your API keys

# ===================
# Tushare Configuration
# ===================
# Tushare API token for stock data
# Get from: https://tushare.pro/document/01013
TUSHARE_TOKEN=

# ===================
# Telegram Configuration
# ===================
# Telegram Bot Token
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8

# Telegram Chat IDs (comma-separated)
TELEGRAM_CHAT_IDS=123456789,987654321

# ===================
# QQ SMTP Configuration
# ===================
# For email notifications
QQ_SMTP_HOST=smtp.qq.com
QQ_SMTP_PORT=587
QQ_SMTP_USER=your_qq_email@qq.com
QQ_SMTP_PASSWORD=your_smtp_password

# ===================
# Tavily Search Configuration
# ===================
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ===================
# Gemini Configuration
# ===================
# Google Gemini API for AI analysis
GEMINI_API_KEY=your_gemini_api_key_here

# ===================
# Anthropic Configuration
# ===================
# Anthropic API for VLM image analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================
# Zhipu AI (智谱) Configuration
# ===================
# 智谱 AI API for LLM analysis
# Get from: https://open.bigmodel.cn/
# 海外版使用: https://open.bigmodel.cn (与国内相同，但API Key不同)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ===================
# UCloud ModelVerse Configuration
# ===================
# UCloud ModelVerse API (兼容 OpenAI 格式)
UMODELVERSE_BASE_URL=https://api.modelverse.cn/v1
UMODELVERSE_API_KEY=

# ===================
# AlphaPAI Configuration
# ===================
# For automated login
ALPHAPAI_LOGIN_URL=https://alphapai.example.com/login
ALPHAPAI_USERNAME=your_username
ALPHAPAI_PASSWORD=your_password

# ===================
# OpenClaw Mode Configuration
# ===================
# Mode: 'dev' (Windows/PyCharm) or 'prod' (Linux)
# Auto-detected if not set: dev on Windows, prod on Linux
OPENCLAW_MODE=dev

# ===================
# OpenViking Configuration
# ===================
# Vector database for local search
OPENVIKING_DB_PATH=~/.openclaw/workspace/data/openviking

# ===================
# Paths
# ===================
WORKSPACE_PATH=~/.openclaw/workspace
